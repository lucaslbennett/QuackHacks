# ---- Core ----
PORT=3000
NODE_ENV=development

# Railway Postgres connection string. In production Railway injects DATABASE_URL
# (internal host, postgres.railway.internal). For LOCAL dev, use the public proxy
# URL instead - either set DATABASE_URL to it, or set DATABASE_PUBLIC_URL (the app
# accepts either, preferring DATABASE_URL when both are present).
# Local value must use the *.proxy.rlwy.net host, NOT *.railway.internal.
DATABASE_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway
# DATABASE_PUBLIC_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway

# 32+ char secret used to encrypt stored IG passwords at rest. Optional in dev.
ENCRYPTION_KEY=

# How many days a user login session stays valid before re-auth is required.
SESSION_TTL_DAYS=30

# ---- Google Gemini (persona + scripts + Stagehand reasoning) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# Nano Banana Pro (Gemini 3 Pro Image) for image generation.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ---- ElevenLabs (voiceover) ----
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ---- fal.ai (image + video generation) ----
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/dev
# Nano Banana (text-to-image) for the onboarding character preview.
FAL_NANO_BANANA_MODEL=fal-ai/nano-banana
FAL_VIDEO_MODEL=fal-ai/kling-video/v1.6/standard/image-to-video

# ---- Browserbase / Stagehand (account creation, posting, scraping) ----
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
STAGEHAND_ENV=BROWSERBASE
# CAPTCHA solving is always on. These boost reCAPTCHA-Enterprise success but are
# PLAN-GATED, so they default to FALSE (enabling them on an ineligible plan makes
# Browserbase session creation fail): proxies need a paid plan (402 otherwise),
# verified/advanced-stealth needs Enterprise (403 otherwise). Turn on only if
# your Browserbase plan supports them. Without them, a CAPTCHA that doesn't
# auto-solve falls back to manual solving via the live session URL.
BROWSERBASE_PROXIES=false
BROWSERBASE_VERIFIED=false
# Custom EXTERNAL proxy for the browser session. Set this to the SAME proxy as
# CAPSOLVER_PROXY (below) so the session egresses from the IP the CAPTCHA is
# solved on — reCAPTCHA Enterprise rejects a token whose solver IP/fingerprint
# doesn't match the page, so matching them is what makes an injected CapSolver
# token actually clear Instagram's "Help us confirm it's you" challenge. Use a
# residential proxy for best results. Leave blank to use the options above.
BROWSERBASE_PROXY_SERVER=
BROWSERBASE_PROXY_USERNAME=
BROWSERBASE_PROXY_PASSWORD=

# ---- CapSolver (programmatic CAPTCHA solving) ----
# Third-party reCAPTCHA solver (https://capsolver.com). When CAPSOLVER_API_KEY
# is set, account creation solves IG's reCAPTCHA (incl. Enterprise) via the
# CapSolver API and injects the token — clearing the challenge even on the FREE
# Browserbase plan (no residential proxies or human solve needed). Leave blank
# to fall back to Browserbase's background solver + manual live-session solve.
# Get the key from your CapSolver dashboard. Check it with: npm run probe:capsolver
CAPSOLVER_API_KEY=
# Optional overrides (sensible defaults shown):
CAPSOLVER_API_BASE=https://api.capsolver.com
CAPSOLVER_POLL_MS=3000
CAPSOLVER_TIMEOUT_MS=120000
# Instagram uses reCAPTCHA *Enterprise*. Solving it as standard v2 returns a
# token IG rejects (the challenge "solves" but never clears), so we force the
# CapSolver Enterprise task type by default. Only set this to false if you point
# the flow at a genuinely non-enterprise reCAPTCHA.
CAPSOLVER_FORCE_ENTERPRISE=true
# Proxy CapSolver solves THROUGH (format: "scheme:host:port:user:pass" or
# "host:port:user:pass"). reCAPTCHA Enterprise binds the token to the solver's
# IP/fingerprint, so a proxyless (datacenter-IP) token gets rejected when the
# Browserbase session submits it from a different IP. Set this to the SAME proxy
# as BROWSERBASE_PROXY_SERVER so the solve IP matches the page IP — that is what
# makes an Enterprise token actually clear the challenge. Leave blank to solve
# proxyless (fine for non-enterprise; usually rejected by Instagram).
CAPSOLVER_PROXY=

# ---- Verification providers (clear IG email/SMS codes automatically) ----
# Email: imap | maildotm | mailosaur | manual
#
# "imap" (MOST RELIABLE — recommended for accounts that must actually work):
# polls a REAL mailbox (e.g. a Gmail with an app password, or any catch-all
# domain you control). Because the address is reputable, Instagram DELIVERS the
# code instead of silently dropping it like it does for disposable domains.
# Set IMAP_* below, plus EMAIL_ALIAS_BASE (e.g. you@gmail.com -> you+ig123@...)
# or EMAIL_CATCHALL_DOMAIN (e.g. ig123@yourdomain.com). Verify with:
#   npm run probe:email
#
# "maildotm" (mail.tm, zero-config default, NO API KEY): provisions a disposable
# inbox and polls it. Convenient for local testing, BUT Meta blocks most
# disposable domains, so the verification email often never arrives. mail.tm and
# mail.gw are both tried automatically (MAILTM_API_BASE, comma-separated).
#
# "mailosaur": DOES NOT WORK for IG — it policy-blocks third-party signup emails.
# "manual": placeholder address; enter the code by hand from the dashboard
# (POST /api/verification/:influencerId/email).
EMAIL_PROVIDER=maildotm

# -- IMAP real-inbox settings (only used when EMAIL_PROVIDER=imap) --
# Gmail example: create an App Password (Google Account -> Security -> 2-Step ->
# App passwords) and use it as IMAP_PASS. Gmail host is imap.gmail.com:993.
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX
# Address every signup alias routes back to (defaults to IMAP_USER). Each signup
# gets a unique alias of this so IG sees a fresh address but it lands in this one
# inbox. EMAIL_ALIAS_MODE: plus (you+slug@dom, default) | dot (Gmail dotted) | none
EMAIL_ALIAS_BASE=
EMAIL_ALIAS_MODE=plus
# OR: a catch-all domain you own (every <anything>@domain reaches the IMAP box).
# Best option — unlimited, real-looking addresses. Overrides EMAIL_ALIAS_BASE.
EMAIL_CATCHALL_DOMAIN=

# -- Disposable-mail settings (only used when EMAIL_PROVIDER=maildotm) --
# Comma-separated mail.tm-compatible endpoints, tried in order.
# MAILTM_API_BASE=https://api.mail.tm,https://api.mail.gw
# Pin a specific domain, or skip ones you've seen IG reject (comma-separated):
# MAILTM_PREFERRED_DOMAIN=
# MAILTM_SKIP_DOMAINS=

# Mailosaur-only (ignored for imap/maildotm/manual):
EMAIL_API_KEY=
MAILOSAUR_SERVER_ID=
# SMS: manual | twilio | sms-activate
SMS_PROVIDER=manual
SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---- Postiz (social-media publishing + Instagram connect) ----
# Get the key from Postiz: Settings -> Developers -> Public API. Used to publish
# influencer posts to connected channels (Instagram, X, TikTok, ...) and to
# generate the in-app "Connect Instagram" OAuth URL.
POSTIZ_API_KEY=
# Cloud by default. For a self-hosted instance, point at https://<host>/public/v1.
POSTIZ_API_BASE=https://api.postiz.com/public/v1
# Default post type when scheduling: schedule | now | draft
POSTIZ_DEFAULT_TYPE=schedule
#
# Instagram OAuth: NOTE these vars are NOT set here. The "Connect Instagram"
# button in the dashboard asks Postiz for an OAuth URL, so the Instagram/Meta
# app credentials live on the POSTIZ server, not in this app:
#   * Postiz Cloud (api.postiz.com): nothing to configure — Postiz already runs
#     the Meta app. POSTIZ_API_KEY above is all you need.
#   * Self-hosted Postiz: set INSTAGRAM_APP_ID / INSTAGRAM_APP_SECRET (and the
#     Meta OAuth redirect URIs) in the POSTIZ instance's own env / docker-compose
#     — see https://docs.postiz.com/providers/instagram. They do not belong here.
# Instagram requires a Business or Creator account either way.

# ---- Scheduler ----
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=20
# When true, the daily planner schedules posts through Postiz (for influencers
# linked to a channel) instead of the Stagehand IG poster.
SCHEDULER_USE_POSTIZ=false

# Public URL where this server is reachable so Postiz can fetch generated media.
# On Railway, RAILWAY_PUBLIC_DOMAIN is used automatically when this is unset.
PUBLIC_BASE_URL=

# Where generated media is written (use a Railway volume to persist).
MEDIA_DIR=media
