# ---- Core ----
PORT=3000
NODE_ENV=development

# Railway Postgres connection string. In production Railway injects DATABASE_URL
# (internal host, postgres.railway.internal). For LOCAL dev, use the public proxy
# URL instead - either set DATABASE_URL to it, or set DATABASE_PUBLIC_URL (the app
# accepts either, preferring DATABASE_URL when both are present).
# Local value must use the *.proxy.rlwy.net host, NOT *.railway.internal.
DATABASE_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway
# DATABASE_PUBLIC_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway

# 32+ char secret used to encrypt stored IG passwords at rest. Optional in dev.
ENCRYPTION_KEY=

# How many days a user login session stays valid before re-auth is required.
SESSION_TTL_DAYS=30

# ---- Google Gemini (persona + scripts + Stagehand reasoning) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# Nano Banana Pro (Gemini 3 Pro Image) — default; best for reference fidelity and
# anatomy. Image generation requires a paid API tier. For faster/cheaper posts use:
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_MODEL=gemini-3-pro-image
# Vision model that reads Instagram's distorted "Confirm you're human" image-code
# challenge (screenshot -> LLM -> typed code). Defaults to GEMINI_MODEL; point at
# a stronger vision model (e.g. gemini-flash-latest) if the reads are unreliable.
# GEMINI_CAPTCHA_MODEL=gemini-flash-lite-latest

# ---- ElevenLabs (voiceover) ----
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ---- Browser Use / Stagehand (account creation, posting, scraping) ----
# Stagehand drives the browser and does the act/extract reasoning, but instead of
# Browserbase it connects to a Browser Use cloud browser over CDP. Browser Use
# ships stealth, anti-fingerprinting, residential proxies, and CAPTCHA bypass on
# by default. Create a key (starts with "bu_") at:
#   https://cloud.browser-use.com/settings?tab=api-keys&new=1
BROWSER_USE_API_KEY=
# By default we create each browser via Browser Use's REST API (POST /browsers).
# This is what makes the API key show as "used" and makes every run appear as a
# real, watchable session in the dashboard (https://cloud.browser-use.com). Set to
# false to use the raw connect-URL instead (works, but sessions are NOT listed in
# the dashboard and the key's "last used" never updates).
BROWSER_USE_REST_SESSIONS=true
# Browser Use Cloud REST API base (v3). Override only if self-hosting/proxying.
BROWSER_USE_API_BASE=https://api.browser-use.com/api/v3
# Stagehand connects to the Browser Use browser via CDP, so keep this LOCAL
# (LOCAL = "don't use Browserbase"; the cdpUrl points Stagehand at Browser Use).
STAGEHAND_ENV=LOCAL
# Fallback CDP/WebSocket endpoint, used ONLY when BROWSER_USE_REST_SESSIONS=false.
BROWSER_USE_CONNECT_HOST=wss://connect.browser-use.com
# Optional residential-proxy country (us, de, jp, gb, ...). Routing IG signup
# through a residential IP greatly reduces how often it throws a CAPTCHA. Leave
# blank to let Browser Use apply its default (us).
BROWSER_USE_PROXY_COUNTRY=
# Optional saved browser-profile UUID (create one in the Browser Use dashboard).
# Loads cookies/localStorage so an Instagram login persists across sessions;
# leave blank to start from a fresh browser each run.
BROWSER_USE_PROFILE_ID=
# Session timeout in MINUTES (Browser Use max 240). Signup can sit on a CAPTCHA or
# email-code step for a while, so this defaults higher than Browser Use's 15.
BROWSER_USE_TIMEOUT_MINUTES=30
# Record sessions so they can be replayed from the dashboard afterwards (small
# extra cost). Off by default; turn on while debugging "what happened" in a run.
BROWSER_USE_RECORDING=false
# Optional FIXED browser viewport (pixels). Leave both blank/0 (recommended) and
# each signup session picks a random COMMON desktop resolution (1920x1080,
# 1536x864, 1366x768, 1440x900, 1600x900, 1280x720) so the screen fingerprint
# blends in instead of presenting one constant automation viewport. Set BOTH to
# pin an exact size (e.g. for reproducible debugging).
BROWSER_USE_SCREEN_WIDTH=
BROWSER_USE_SCREEN_HEIGHT=

# ---- CapSolver (programmatic CAPTCHA solving) ----
# Third-party reCAPTCHA solver (https://capsolver.com). OPTIONAL with Browser Use,
# which bypasses most CAPTCHAs in-browser on its own — keep this as a fallback for
# Instagram's reCAPTCHA Enterprise. When CAPSOLVER_API_KEY is set, account
# creation solves IG's reCAPTCHA via the CapSolver API and injects the token.
# Leave blank to rely on Browser Use's built-in bypass + the manual live-session
# solve. Get the key from your CapSolver dashboard. Check it: npm run probe:capsolver
CAPSOLVER_API_KEY=
# Optional overrides (sensible defaults shown):
CAPSOLVER_API_BASE=https://api.capsolver.com
CAPSOLVER_POLL_MS=3000
CAPSOLVER_TIMEOUT_MS=120000
# Instagram uses reCAPTCHA *Enterprise*. Solving it as standard v2 returns a
# token IG rejects (the challenge "solves" but never clears), so we force the
# CapSolver Enterprise task type by default. Only set this to false if you point
# the flow at a genuinely non-enterprise reCAPTCHA.
CAPSOLVER_FORCE_ENTERPRISE=true
# Proxy CapSolver solves THROUGH (format: "scheme:host:port:user:pass" or
# "host:port:user:pass"). reCAPTCHA Enterprise binds the token to the solver's
# IP/fingerprint, so a proxyless (datacenter-IP) token gets rejected when the
# browser submits it from a different IP. For the best CapSolver success rate,
# point this at a residential proxy in the same region as BROWSER_USE_PROXY_COUNTRY
# so the solve IP matches the page IP. Leave blank to solve proxyless (fine for
# non-enterprise; usually rejected by Instagram).
CAPSOLVER_PROXY=
# CapSolver also powers the BACKUP solver for Instagram's distorted "Confirm
# you're human" image-code challenge (the "enter the code from the image" step),
# via its purpose-built ImageToText OCR — used when the LLM (Gemini) misreads it.
# This works with the same CAPSOLVER_API_KEY above (no proxy needed). Pick the
# OCR module: "common" = general alphanumeric (default); "number" = digits only
# (more accurate for IG's numeric codes). https://docs.capsolver.com/guide/recognition/ImageToTextTask/
CAPSOLVER_IMAGE_MODULE=common

# ---- Verification providers (clear IG email/SMS codes automatically) ----
// Email: imap | maildotm | mailosaur | manual
#
# "imap" (recommended — no DNS): polls Fastmail (or any IMAP inbox) and rotates
# across EMAIL_ALIAS_BASES — distinct @fastmail.com aliases you create in
# Fastmail Settings → My email addresses. Each signup gets base+tag@fastmail.com;
# rotate bases when Instagram burns one (EMAIL_EXCLUDE_BASES / auto-burn).
# Verify with: npm run probe:email
#
# "maildotm": disposable mail.tm inboxes — Meta often blocks delivery.
# "mailosaur": policy-blocks Instagram signup emails.
# "manual": enter codes by hand from the dashboard.
EMAIL_PROVIDER=imap

# -- IMAP real-inbox settings (only used when EMAIL_PROVIDER=imap) --
# Gmail example: create an App Password (Google Account -> Security -> 2-Step ->
# App passwords) and use it as IMAP_PASS. Gmail host is imap.gmail.com:993.
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX
# Fastmail aliases to rotate (comma-separated). Create each in Fastmail → Settings
# → My email addresses → New email address. All deliver to the same inbox as IMAP_USER.
EMAIL_ALIAS_BASES=
# Bases Instagram has burned — never reused. Comma-separated emails.
# EMAIL_EXCLUDE_BASES=lucasfasto@fastmail.com
EMAIL_ALIAS_MODE=plus
# Optional: custom-domain catch-all (requires DNS). Leave blank for Fastmail-only.
EMAIL_CATCHALL_DOMAIN=

# -- Disposable-mail settings (only used when EMAIL_PROVIDER=maildotm) --
# Comma-separated mail.tm-compatible endpoints, tried in order.
# MAILTM_API_BASE=https://api.mail.tm,https://api.mail.gw
# Pin a specific domain, or skip ones you've seen IG reject (comma-separated):
# MAILTM_PREFERRED_DOMAIN=
# MAILTM_SKIP_DOMAINS=

# Mailosaur-only (ignored for imap/maildotm/manual):
EMAIL_API_KEY=
MAILOSAUR_SERVER_ID=
# SMS: manual | twilio | sms-activate
SMS_PROVIDER=manual
SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---- Postiz (social-media publishing + Instagram connect) ----
# Get the key from Postiz: Settings -> Developers -> Public API. Used to publish
# influencer posts to connected channels (Instagram, X, TikTok, ...) and to
# generate the in-app "Connect Instagram" OAuth URL.
POSTIZ_API_KEY=
# Cloud by default. For a self-hosted instance, point at https://<host>/public/v1.
POSTIZ_API_BASE=https://api.postiz.com/public/v1
# Default post type when scheduling: schedule | now | draft
POSTIZ_DEFAULT_TYPE=schedule
#
# Instagram OAuth: NOTE these vars are NOT set here. The "Connect Instagram"
# button in the dashboard asks Postiz for an OAuth URL, so the Instagram/Meta
# app credentials live on the POSTIZ server, not in this app:
#   * Postiz Cloud (api.postiz.com): nothing to configure — Postiz already runs
#     the Meta app. POSTIZ_API_KEY above is all you need.
#   * Self-hosted Postiz: set INSTAGRAM_APP_ID / INSTAGRAM_APP_SECRET (and the
#     Meta OAuth redirect URIs) in the POSTIZ instance's own env / docker-compose
#     — see https://docs.postiz.com/providers/instagram. They do not belong here.
# Instagram requires a Business or Creator account either way.

# ---- Scheduler ----
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=20
# When true, the daily planner schedules posts through Postiz (for influencers
# linked to a channel) instead of the Stagehand IG poster.
SCHEDULER_USE_POSTIZ=false

# Public URL where this server is reachable so Postiz can fetch generated media.
# On Railway, RAILWAY_PUBLIC_DOMAIN is used automatically when this is unset.
PUBLIC_BASE_URL=

# Where generated media (images/audio/video) is written + served from (/media).
# Local default is fine. In production on an ephemeral filesystem (Railway),
# mount a persistent volume and set this to its mount path so generated images
# survive redeploys — otherwise stored /media URLs 404 after a redeploy.
#   e.g. mount a volume at /data/media, then: MEDIA_DIR=/data/media
MEDIA_DIR=media
