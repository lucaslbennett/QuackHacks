# ---- Core ----
PORT=3000
NODE_ENV=development

# Railway Postgres connection string. In production Railway injects DATABASE_URL
# (internal host, postgres.railway.internal). For LOCAL dev, use the public proxy
# URL instead - either set DATABASE_URL to it, or set DATABASE_PUBLIC_URL (the app
# accepts either, preferring DATABASE_URL when both are present).
# Local value must use the *.proxy.rlwy.net host, NOT *.railway.internal.
DATABASE_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway
# DATABASE_PUBLIC_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway

# 32+ char secret used to encrypt stored IG passwords at rest. Optional in dev.
ENCRYPTION_KEY=

# How many days a user login session stays valid before re-auth is required.
SESSION_TTL_DAYS=30

# ---- Google Gemini (persona + scripts + Stagehand reasoning) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# Nano Banana Pro (Gemini 3 Pro Image) for image generation.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ---- ElevenLabs (voiceover) ----
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ---- fal.ai (image + video generation) ----
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/dev
FAL_VIDEO_MODEL=fal-ai/kling-video/v1.6/standard/image-to-video

# ---- Browserbase / Stagehand (account creation, posting, scraping) ----
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
STAGEHAND_ENV=BROWSERBASE

# ---- Verification providers (clear IG email/SMS codes automatically) ----
# Email: manual | mailosaur
EMAIL_PROVIDER=manual
EMAIL_API_KEY=
MAILOSAUR_SERVER_ID=
# SMS: manual | twilio | sms-activate
SMS_PROVIDER=manual
SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---- Scheduler ----
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=20

# Where generated media is written (use a Railway volume to persist).
MEDIA_DIR=media
