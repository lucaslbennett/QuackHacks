{
  "name": "ai-influencer-os",
  "version": "1.0.0",
  "description": "AI Influencer OS - autonomous AI influencer spawning, content generation, and posting platform",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/scripts/freePort.js 3000 && node server/index.js",
    "dev:all": "./dev.sh",
    "migrate": "node server/db/migrate.js",
    "build": "npm --prefix web install --no-audit --no-fund && npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "test:signup": "node server/scripts/signupTest.js",
    "test:signup:loop": "node server/scripts/signupTest.js --runs 5 --all",
    "probe:email": "node server/scripts/probeEmail.js",
    "probe:mailosaur": "node server/scripts/probeMailosaur.js",
    "probe:birthday": "node server/scripts/probeBirthday.js",
    "probe:capsolver": "node server/scripts/probeCapsolver.js",
    "probe:captcha": "node server/scripts/probeCaptchaOcr.js",
    "probe:browseruse": "node server/scripts/probeBrowserUse.js"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.4.0",
    "@elevenlabs/elevenlabs-js": "^2.49.0",
    "@google/genai": "^2.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "imapflow": "^1.3.4",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  }
}
